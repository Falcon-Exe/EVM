<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vote - College EVM Wizard</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="styles.css">
</head>

<body>
    <div class="container wizard">
        <!-- Progress Bar -->
        <div id="wizard-header" class="header">
            <span id="step-count" style="font-weight: 600; color: var(--primary);">Position 1 of 5</span>
            <div class="progress-container">
                <div id="progress-bar" class="progress-bar"></div>
            </div>
        </div>

        <!-- Voting Steps -->
        <div id="step-container" class="step-content">
            <h2 id="position-name">Loading...</h2>
            <div id="candidates-grid" class="candidates-grid">
                <!-- Cards injected here -->
            </div>
            <div class="controls">
                <button id="vote-btn" class="btn-vote" style="background: var(--primary);" disabled
                    onclick="showModal()">VOTE</button>
            </div>
        </div>

        <!-- Final Review Screen (Hidden initially) -->
        <div id="review-container" class="step-content hidden">
            <h2>Review Your Selections</h2>
            <div id="review-list" class="review-list">
                <!-- Summary items injected here -->
            </div>
            <div class="controls" style="flex-direction: column; gap: 10px;">
                <button onclick="submitFinalVote()" class="btn-vote"
                    style="background: var(--success); width: 400px;">SUBMIT FINAL VOTE</button>
            </div>
        </div>
    </div>

    <!-- Confirmation Modal -->
    <div id="modal-overlay" class="modal-overlay">
        <div class="modal">
            <h3 id="modal-title">Confirm Your Selection</h3>
            <p id="modal-desc"></p>
            <div class="modal-actions">
                <button onclick="confirmVote()" class="btn-confirm" style="flex: 1;">Confirm</button>
                <button onclick="closeModal()" class="btn-change" style="flex: 1;">Change Selection</button>
            </div>
        </div>
    </div>

    <!-- Success Screen Overlay -->
    <div id="success-overlay" class="modal-overlay" style="background: white;">
        <div class="modal" style="box-shadow: none;">
            <div style="font-size: 6rem; color: var(--success); margin-bottom: 20px;">✓</div>
            <h1 style="color: var(--success); font-size: 3rem; margin-bottom: 10px;">VOTE RECORDED!</h1>
            <p style="font-size: 1.5rem; color: var(--text); font-weight: 700;">Thank you for voting.</p>
            <p style="margin-top: 40px; color: var(--text-muted);">Please return to the verification desk.</p>
            <p style="margin-top: 10px; font-size: 0.9rem; color: #cbd5e1;">Restarting in 3 seconds...</p>
        </div>
    </div>

    <script>
        const POSITION_ORDER = ['Chairman', 'General Secretary', 'Treasurer', 'CUC', 'Fine Arts'];

        function playBeep(frequency = 880, duration = 500) {
            const context = new (window.AudioContext || window.webkitAudioContext)();
            const oscillator = context.createOscillator();
            const gainNode = context.createGain();

            oscillator.type = 'square';
            oscillator.frequency.setValueAtTime(frequency, context.currentTime);
            oscillator.connect(gainNode);
            gainNode.connect(context.destination);

            gainNode.gain.setValueAtTime(0.1, context.currentTime);
            oscillator.start();
            oscillator.stop(context.currentTime + (duration / 1000));
        }

        let allData = {};
        let positions = [];
        let currentStep = 0;
        let selections = {}; // { positionName: { id, name } }

        async function initWizard() {
            const res = await fetch('/api/candidates');
            allData = await res.json();

            // Sort positions by hierarchy
            positions = Object.keys(allData).sort((a, b) => {
                let indexA = POSITION_ORDER.indexOf(a);
                let indexB = POSITION_ORDER.indexOf(b);
                if (indexA === -1) indexA = 99;
                if (indexB === -1) indexB = 99;
                return indexA - indexB;
            });

            renderStep();
        }

        function renderStep() {
            if (currentStep >= positions.length) {
                showReview();
                return;
            }

            const posName = positions[currentStep];
            const candidates = allData[posName];

            // Update Header
            document.getElementById('step-count').textContent = `Step ${currentStep + 1} of ${positions.length}`;
            const progress = ((currentStep) / positions.length) * 100;
            document.getElementById('progress-bar').style.width = `${progress}%`;

            // Update Content
            document.getElementById('position-name').textContent = posName;
            const grid = document.getElementById('candidates-grid');
            grid.innerHTML = '';

            candidates.forEach(cand => {
                const card = document.createElement('div');
                card.className = 'candidate-card';
                if (selections[posName] && selections[posName].id === cand.id) {
                    card.classList.add('selected');
                }
                card.onclick = () => selectCandidate(cand, card);
                card.innerHTML = `<span class="name">${cand.name}</span>`;
                grid.appendChild(card);
            });

            checkBtnState();
        }

        function selectCandidate(cand, element) {
            const posName = positions[currentStep];
            selections[posName] = { id: cand.id, name: cand.name };

            document.querySelectorAll('.candidate-card').forEach(c => c.classList.remove('selected'));
            element.classList.add('selected');
            checkBtnState();
        }

        function checkBtnState() {
            const posName = positions[currentStep];
            document.getElementById('vote-btn').disabled = !selections[posName];
        }

        function showModal() {
            const posName = positions[currentStep];
            const selection = selections[posName];
            document.getElementById('modal-desc').innerHTML = `You selected <strong>${selection.name}</strong> for <strong>${posName}</strong>`;
            document.getElementById('modal-overlay').style.display = 'flex';
        }

        function closeModal() {
            document.getElementById('modal-overlay').style.display = 'none';
        }

        function confirmVote() {
            closeModal();
            currentStep++;
            renderStep();
        }

        function showReview() {
            document.getElementById('progress-bar').style.width = '100%';
            document.getElementById('step-container').classList.add('hidden');
            document.getElementById('wizard-header').classList.add('hidden');
            document.getElementById('review-container').classList.remove('hidden');

            const list = document.getElementById('review-list');
            list.innerHTML = '';
            for (const pos in selections) {
                list.innerHTML += `
                    <div class="review-item">
                        <span class="review-pos">${pos}</span>
                        <span class="review-cand">${selections[pos].name}</span>
                    </div>
                `;
            }
        }

        function editSelections() {
            currentStep = 0;
            document.getElementById('step-container').classList.remove('hidden');
            document.getElementById('wizard-header').classList.remove('hidden');
            document.getElementById('review-container').classList.add('hidden');
            renderStep();
        }

        async function submitFinalVote() {
            const voteIds = Object.values(selections).map(s => s.id);

            try {
                const response = await fetch('/api/submit-vote', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ votes: voteIds })
                });

                if (response.ok) {
                    playBeep(); // Audio feedback
                    document.getElementById('success-overlay').style.display = 'flex';
                    sessionStorage.clear();
                    setTimeout(() => {
                        window.location.href = 'index.html';
                    }, 3500);
                } else {
                    const data = await response.json();
                    alert("Error: " + data.error);
                }
            } catch (err) {
                alert("Submission failed. Check connection.");
            }
        }

        // Prevent going back
        window.history.pushState(null, null, window.location.href);
        window.onpopstate = function () {
            window.history.go(1);
        };

        initWizard();
    </script>
</body>

</html>