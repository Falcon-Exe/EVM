<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel - College EVM</title>
    <link rel="stylesheet" href="styles.css">
</head>

<body>
    <div id="live-toast" style="display: none;">
        <span class="toast-icon">🚀</span>
        <div class="toast-content">
            <b>NEW VOTE RECEIVED!</b>
            <span id="toast-msg">The dashboard has been updated.</span>
        </div>
    </div>
    <div class="container" style="max-width: 900px;" id="admin-login-view">
        <h1>Admin Login</h1>
        <div class="form-group">
            <input type="password" id="adminPassword" placeholder="Admin Password">
        </div>
        <button onclick="adminLogin()">Login</button>
    </div>

    <div class="container hidden" style="max-width: 1000px;" id="admin-dashboard">
        <div class="header"
            style="text-align: left; border-bottom: 2px solid var(--border); margin-bottom: 30px; padding-bottom: 10px;">
            <h1 style="color: var(--primary); margin:0;">Admin Dashboard</h1>
            <p id="network-info"
                style="font-size: 0.95rem; font-weight: 700; color: var(--secondary); margin: 5px 0 0 0;">
            </p>
        </div>

        <!-- Verification Desk Section -->
        <div
            style="background: #f8fafc; padding: 25px; border-radius: var(--radius-md); margin-bottom:30px; border: 2px solid #e2e8f0;">
            <h3 style="margin-bottom: 20px;">Voter Verification Desk</h3>
            <div style="display: flex; gap: 10px; margin-bottom: 15px;">
                <input type="text" id="voterSearch" placeholder="Enter CIC or Register Number" style="flex: 1;">
                <button onclick="searchVoter()" style="width: 120px;">Search</button>
            </div>
            <div id="voter-details" class="hidden"
                style="background: white; padding: 20px; border-radius: 10px; border-left: 5px solid var(--primary);">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <div>
                        <p id="v-name"
                            style="font-weight: 700; font-size: 1.2rem; margin-bottom: 5px; color: var(--text);">
                            Name
                        </p>
                        <p id="v-info" style="font-size: 0.9rem; color: var(--text-muted);">CIC: - | Reg: -</p>
                        <p id="v-status" style="margin-top: 10px; font-weight: 600;"></p>
                    </div>
                    <button id="approve-btn" onclick="approveSelectedVoter()"
                        style="background: var(--success); display: none;">Approve to Vote</button>
                </div>
            </div>
        </div>

        <div class="admin-controls">
            <button id="toggle-btn" onclick="toggleElection()" style="width: auto; padding: 10px 25px;"></button>
            <button onclick="exportResults()" class="btn-secondary">Export Results</button>
            <button onclick="exportAudit()" class="btn-outline"
                style="border-color: var(--secondary); color: var(--secondary);">Security Audit Log</button>
            <button onclick="location.reload()" class="btn-outline">Refresh Dashboard</button>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <span class="stat-label">Total Voters</span>
                <span id="stat-total" class="stat-value" style="color: var(--primary);">0</span>
            </div>
            <div class="stat-card">
                <span class="stat-label">Votes Cast</span>
                <span id="stat-casted" class="stat-value" style="color: var(--success);">0</span>
            </div>
            <div class="stat-card">
                <span class="stat-label">Remaining</span>
                <span id="stat-remaining" class="stat-value" style="color: var(--danger);">0</span>
            </div>
        </div>

        <div id="results-grid" class="results-grid">
            <!-- Position cards will be injected here -->
        </div>
    </div>

    <script>
        let electionStatus = 'stopped';

        async function adminLogin() {
            const password = document.getElementById('adminPassword').value;
            const res = await fetch('/api/admin/login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ password })
            });

            if (res.ok) {
                showDashboard();
            } else {
                alert("Invalid Admin Password");
            }
        }

        function showDashboard() {
            document.getElementById('admin-login-view').classList.add('hidden');
            document.getElementById('admin-dashboard').classList.remove('hidden');
            loadDashboard();
        }

        async function checkSession() {
            const res = await fetch('/api/admin/status-check');
            if (res.ok) {
                showDashboard();
                loadNetworkInfo();
            }
        }

        async function loadNetworkInfo() {
            const res = await fetch('/api/admin/network-info');
            const nets = await res.json();
            const infoP = document.getElementById('network-info');
            let ips = [];
            for (const name in nets) ips.push(...nets[name]);
            if (ips.length > 0) {
                infoP.textContent = `Booth URL: http://${ips[0]}:3000`;
            }
        }

        let lastCastedCount = -1;

        async function pollVotes() {
            if (document.getElementById('admin-dashboard').classList.contains('hidden')) return;

            try {
                const res = await fetch('/api/admin/voter-stats');
                const stats = await res.json();

                if (lastCastedCount !== -1 && stats.casted > lastCastedCount) {
                    showToast(`Vote #${stats.casted} has been recorded!`);
                    loadDashboard(); // Refresh UI
                }
                lastCastedCount = stats.casted;
            } catch (e) { }

            setTimeout(pollVotes, 3000); // Poll every 3 seconds
        }

        function showToast(msg) {
            const toast = document.getElementById('live-toast');
            document.getElementById('toast-msg').textContent = msg;
            playBeep(880, 150); // Notification beep
            toast.style.display = 'flex';
            setTimeout(() => toast.classList.add('show'), 10);

            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => toast.style.display = 'none', 500);
            }, 5000);
        }

        document.addEventListener('DOMContentLoaded', () => {
            checkSession();
            pollVotes();
        });

        const POSITION_ORDER = ['Chairman', 'General Secretary', 'Treasurer', 'CUC', 'Fine Arts'];

        async function loadDashboard() {
            const statusRes = await fetch('/api/status');
            const statusData = await statusRes.json();
            electionStatus = statusData.status;
            updateStatusUI();

            const statsRes = await fetch('/api/admin/voter-stats');
            const stats = await statsRes.json();
            document.getElementById('stat-total').textContent = stats.total;
            document.getElementById('stat-casted').textContent = stats.casted;
            document.getElementById('stat-remaining').textContent = stats.total - stats.casted;

            const res = await fetch('/api/admin/results');
            const results = await res.json();

            // Group results by position
            const grouped = {};
            results.forEach(row => {
                if (!grouped[row.position]) grouped[row.position] = [];
                grouped[row.position].push(row);
            });

            // Sort positions by hierarchy
            const sortedPositions = Object.keys(grouped).sort((a, b) => {
                let indexA = POSITION_ORDER.indexOf(a);
                let indexB = POSITION_ORDER.indexOf(b);
                if (indexA === -1) indexA = 99;
                if (indexB === -1) indexB = 99;
                return indexA - indexB;
            });

            const grid = document.getElementById('results-grid');
            grid.innerHTML = '';

            sortedPositions.forEach(pos => {
                const candidates = grouped[pos];
                const totalPositionVotes = candidates.reduce((sum, c) => sum + c.votes, 0);

                let cardHtml = `
                    <div class="position-card">
                        <div class="position-header">
                            <span>${pos}</span>
                            <span style="font-size: 0.8rem; opacity: 0.8;">${totalPositionVotes} votes</span>
                        </div>
                        <div class="card-body">
                `;

                candidates.forEach(c => {
                    cardHtml += `
                        <div class="candidate-row">
                            <span class="cand-name">${c.name}</span>
                            <span class="vote-badge">${c.votes}</span>
                        </div>
                    `;
                });

                cardHtml += `</div></div>`;
                grid.innerHTML += cardHtml;
            });
        }

        let selectedVoterId = null;

        async function searchVoter() {
            const query = document.getElementById('voterSearch').value.trim();
            if (!query) return;

            const res = await fetch(`/api/admin/voters/${query}`);
            if (!res.ok) {
                const errData = await res.json();
                alert(`Error: ${errData.error || 'Server error'}`);
                return;
            }

            const data = await res.json();
            const details = document.getElementById('voter-details');
            const approveBtn = document.getElementById('approve-btn');
            const statusText = document.getElementById('v-status');

            if (data && data.length > 0) {
                const voter = data[0];
                selectedVoterId = voter.id;
                details.classList.remove('hidden');
                document.getElementById('v-name').textContent = voter.name;
                document.getElementById('v-info').textContent = `CIC: ${voter.cic_no} | Reg: ${voter.reg_no}`;

                if (voter.has_voted) {
                    statusText.textContent = "Status: ALREADY VOTED";
                    statusText.style.color = "var(--danger)";
                    approveBtn.style.display = 'none';
                } else if (voter.approved) {
                    statusText.textContent = "Status: APPROVED (Ready to vote)";
                    statusText.style.color = "var(--success)";
                    approveBtn.style.display = 'none';
                } else {
                    statusText.textContent = "Status: PENDING VERIFICATION";
                    statusText.style.color = "#eab308";
                    approveBtn.style.display = 'block';
                }
            } else {
                alert("No voter found with this ID.");
                details.classList.add('hidden');
            }
        }

        async function approveSelectedVoter() {
            if (!selectedVoterId) return;
            const res = await fetch('/api/admin/approve-voter', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: selectedVoterId })
            });

            if (res.ok) {
                alert("Voter Approved Successfully!");
                document.getElementById('voter-details').classList.add('hidden');
                document.getElementById('voterSearch').value = '';
                document.getElementById('voterSearch').focus();
                loadDashboard();
            }
        }

        function updateStatusUI() {
            const btn = document.getElementById('toggle-btn');
            if (electionStatus === 'running') {
                btn.textContent = "Stop Election";
                btn.style.backgroundColor = "var(--danger)";
            } else {
                btn.textContent = "Start Election";
                btn.style.backgroundColor = "var(--success)";
            }
        }

        async function toggleElection() {
            const newStatus = electionStatus === 'running' ? 'stopped' : 'running';
            await fetch('/api/admin/toggle-election', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status: newStatus })
            });
            electionStatus = newStatus;
            updateStatusUI();
        }

        function exportResults() {
            window.location.href = '/api/admin/export';
        }

        function exportAudit() {
            window.location.href = '/api/admin/export-audit';
        }
    </script>
</body>

</html>